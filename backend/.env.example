# ================================================================================
# INTEGRA360 - Configuración de Entorno Backend
# ================================================================================
# Este archivo define todas las variables de entorno necesarias para ejecutar
# el servidor backend de Integra360. Copia este archivo a .env y ajusta los
# valores según tu entorno (desarrollo, staging, producción).
#
# Nota: Nunca commites el archivo .env real. Siempre usa .env.example como
# referencia de plantilla.
# ================================================================================

# ================================================================================
# 1. CONFIGURACIÓN DE ENTORNO Y PUERTO
# ================================================================================

# NODE_ENV: Define el ambiente de ejecución de la aplicación
# Valores: development | staging | production
# - development: Activa logs verbosos, desactiva optimizaciones, habilita hot-reload
# - staging: Entorno pre-producción similar a prod pero con más debugging
# - production: Modo optimizado, logs limitados, todas las validaciones habilitadas
NODE_ENV=development

# PORT: Puerto en el cual escucha el servidor Express
# Desarrollo: 3000 (permite múltiples instancias)
# Producción: Usar 8080 o puerto asignado por orquestador (k8s, Docker, etc.)
PORT=3000

# API_PUBLIC_BASE_URL: URL pública base de la API para metadata de OpenAPI/Swagger
# Desarrollo: dejar vacío para usar fallback automático (http://localhost:PORT)
# Staging: https://api-staging.integra360.com
# Producción: https://api.integra360.com
# Nota: NO incluir /api/v1 al final; debe ser solo base URL del host API
API_PUBLIC_BASE_URL=

# ================================================================================
# 2. CONFIGURACIÓN DE BASE DE DATOS (MySQL)
# ================================================================================

# DATABASE_URL: Cadena de conexión a MySQL para Prisma ORM
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Desarrollo: localhost:3306 (conexión local)
# Producción: Usar host RDS/Cloud, credenciales seguros, puerto 3306
# Nota: Para puertos no estándar (ej. 5433), incluir explícitamente:
#   mysql://usuario:pass@localhost:5433/db
DATABASE_URL="mysql://root:MySQL#2024$@localhost:3306/integra360"

# DB_LOG_LEVEL: Nivel de logging para operaciones de base de datos
# Valores: query | info | warn | error
# - query: Muestra todas las consultas SQL (usar solo en desarrollo)
# - info: Operaciones importantes
# - warn: Solo advertencias
# - error: Solo errores críticos
# Producción: Usar 'error' o 'warn' para evitar logs verbosos
DB_LOG_LEVEL=query

# ================================================================================
# 3. CONFIGURACIÓN DE AUTENTICACIÓN Y SEGURIDAD JWT
# ================================================================================

# JWT_ACCESS_SECRET: Llave secreta para firmar tokens de acceso
# Requerimiento: Mínimo 32 caracteres aleatorios
# ⚠️ CRÍTICO: Cambiar en PRODUCCIÓN. Usar valor fuerte (openssl rand -hex 32)
# Nota: Si cambias esta llave, todos los tokens existentes se invalidan
JWT_ACCESS_SECRET=change_this_access_secret_min_32_chars_strong_random

# JWT_REFRESH_SECRET: Llave secreta para firmar tokens de refresco
# Requerimiento: Diferente a JWT_ACCESS_SECRET, mínimo 32 caracteres
# ⚠️ CRÍTICO: Cambiar en PRODUCCIÓN
# Nota: Idealmente rotarla cada 90 días en producción
JWT_REFRESH_SECRET=change_this_refresh_secret_min_32_chars_strong_random

# JWT_ACCESS_EXPIRES_IN: Tiempo de expiración del token de acceso
# Formato: Acepta unidades (ms, s, m, h, d)
# Recomendado: 15m (corto, por seguridad)
# Producción: No exceder 1h
JWT_ACCESS_EXPIRES_IN=15m

# JWT_REFRESH_EXPIRES_IN: Tiempo de expiración del token de refresco
# Formato: Acepta unidades (ms, s, m, h, d)
# Recomendado: 7d (permite sesiones duraderas pero seguras)
# Producción: 14d máximo
JWT_REFRESH_EXPIRES_IN=7d

# JWT_ALGORITHM: Algoritmo para firmar JWT (cuando se implemente rotación de claves)
# Valores: HS256 (HMAC SHA-256), RS256 (RSA, para mult-signatarios)
# Actual: HS256 (actual setup)
JWT_ALGORITHM=HS256

# APP_KEY: Llave maestra de aplicación para encriptación general
# Requerimiento: Base64 encoded, 32 caracteres mínimo
# Uso: Encriptación de datos sensibles, cookies, etc.
# ⚠️ CRÍTICO: Cambiar en PRODUCCIÓN
APP_KEY=change_this_app_key_base64_32_chars

# ================================================================================
# 4. CONFIGURACIÓN DE CORS (Cross-Origin Resource Sharing)
# ================================================================================

# CORS_ORIGIN: Origen(es) permitido(s) para solicitudes CORS
# Desarrollo: http://localhost:5173 (Vite frontend dev)
# Staging: https://staging.integra360.com
# Producción: https://integra360.com
# Múltiples: Separar con coma (sin espacios): http://localhost:5173,https://app.integra360.com
CORS_ORIGIN=http://localhost:5173

# CORS_METHODS: Métodos HTTP permitidos en CORS
# Default: GET, HEAD, PUT, PATCH, POST, DELETE
# Nota: OPTIONS se auto-incluye
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE

# CORS_CREDENTIALS: Permitir envío de credenciales (cookies, headers auth)
# Valores: true | false
# Desarrollo/Producción: true (para mantener sesiones cross-origin)
CORS_CREDENTIALS=true

# ================================================================================
# 5. CONFIGURACIÓN DE API DOCUMENTATION (Swagger/OpenAPI)
# ================================================================================

# SWAGGER_ENABLED: Habilitar/deshabilitar interfaz Swagger UI
# Valores: true | false
# Desarrollo: true (para testing y documentación)
# Staging: true (revisar antes de desplegar a prod)
# Producción: false (proteger endpoints de documentación)
SWAGGER_ENABLED=true

# SWAGGER_USERNAME: Usuario para autenticar acceso a Swagger UI
# Requerimiento: No dejar en blanco en producción
# Nota: Solo se usa si NODE_ENV=production
SWAGGER_USERNAME=docs

# SWAGGER_PASSWORD: Contraseña para autenticar acceso a Swagger UI
# ⚠️ CRÍTICO: Cambiar en PRODUCCIÓN. Usar contraseña fuerte
# Nota: Solo se usa si NODE_ENV=production
SWAGGER_PASSWORD=change_this_docs_password

# ================================================================================
# 6. CONFIGURACIÓN DE LOGS
# ================================================================================

# LOG_LEVEL: Nivel mínimo de severidad para logs
# Valores: trace | debug | info | warn | error | fatal | silent
# Desarrollo: debug (máximo detalle para troubleshooting)
# Staging: info (importante y errores)
# Producción: warn (solo problemas significativos)
LOG_LEVEL=debug

# LOG_FORMAT: Formato de salida de logs
# Valores: json | pretty
# Desarrollo: pretty (legible en consola)
# Producción: json (para parsear en sistemas de análisis ELK, DataDog, etc.)
LOG_FORMAT=pretty

# LOG_FILE: Archivo para almacenar logs (opcional)
# Ruta: logs/app.log (se crea automáticamente)
# Nota: En producción, integrar con sistema centralizador (ELK, CloudWatch, etc.)
LOG_FILE=logs/app.log

# ================================================================================
# 7. CONFIGURACIÓN REGIONAL Y LOCALIZACIÓN
# ================================================================================

# TZ: Zona horaria de la aplicación
# Valor: America/Santiago (zona horaria de Chile)
# Nota: Afecta timestamps en logs, base de datos, APIs de fecha
# Lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Santiago

# LOCALE: Código de idioma/región
# Valor: es-CL (Español - Chile)
# Uso: Localización de mensajes, formatos de fecha, moneda
LOCALE=es-CL

# CURRENCY: Código de moneda ISO 4217
# Valor: CLP (Peso Chileno)
# Uso: Formateo de valores monetarios, conversiones de divisa
CURRENCY=CLP

# CURRENCY_SYMBOL: Símbolo de moneda para mostrar en UI
# Valor: $ (Peso Chileno)
# Nota: Diferente al símbolo de dólar USD
CURRENCY_SYMBOL=$

# DATE_FORMAT: Formato de fechas en la aplicación
# Valor: DD/MM/YYYY (estándar en Latinoamérica)
# Alternativas: YYYY-MM-DD (ISO), MM/DD/YYYY (US)
DATE_FORMAT=DD/MM/YYYY

# TIME_FORMAT: Formato de hora
# Valor: HH:mm:ss (24 horas)
# Alternativa: hh:mm:ss A (12 horas con AM/PM)
TIME_FORMAT=HH:mm:ss

# NUMBER_FORMAT: Separador decimal para números
# Valor: , (coma en Latinoamérica)
# Alternativa: . (punto en países anglosajones)
NUMBER_DECIMAL_SEPARATOR=,

# NUMBER_THOUSANDS_SEPARATOR: Separador de miles
# Valor: . (punto en Latinoamérica)
# Alternativa: , (coma en países anglosajones)
NUMBER_THOUSANDS_SEPARATOR=.

# ================================================================================
# 8. CONFIGURACIÓN DE RATE LIMITING (Límite de Solicitudes)
# ================================================================================

# RATE_LIMIT_WINDOW: Ventana de tiempo para contar solicitudes (en minutos)
# Valor: 15 (15 minutos)
# Nota: Define el período de reset del contador
RATE_LIMIT_WINDOW=15

# RATE_LIMIT_MAX_REQUESTS: Máximo de solicitudes por ventana por IP
# Valor: 100 (100 solicitudes en 15 minutos)
# Desarrollo: 1000 (permisivo para testing)
# Producción: 100-200 (restrictivo contra abuso)
RATE_LIMIT_MAX_REQUESTS=100

# ================================================================================
# 9. CONFIGURACIÓN DE CACHE
# ================================================================================

# CACHE_DRIVER: Sistema de almacenamiento en caché
# Valores: memory | redis | memcached | file
# Desarrollo: memory (simple, en RAM)
# Producción: redis (distribuido, persistente, rápido)
CACHE_DRIVER=memory

# CACHE_REDIS_URL: Conexión a servidor Redis (si CACHE_DRIVER=redis)
# Formato: redis://[:password]@host:port/db
# Ejemplo con contraseña: redis://:secure_password@redis:6379/0
CACHE_REDIS_URL=redis://localhost:6379/0

# CACHE_TTL: Tiempo de vida de cache por defecto (en segundos)
# Valor: 3600 (1 hora)
# Nota: Cada clave puede sobrescribir este valor
CACHE_TTL=3600

# ================================================================================
# 10. CONFIGURACIÓN DE SESIONES
# ================================================================================

# SESSION_DRIVER: Sistema de almacenamiento de sesiones
# Valores: memory | file | redis | database
# Desarrollo: memory (simple)
# Producción: redis (distribuido) o database (persistencia)
SESSION_DRIVER=memory

# SESSION_COOKIE_NAME: Nombre de la cookie de sesión
# Valor: INTEGRA360_SESSION
# Nota: Debe ser único si hay múltiples apps en el mismo dominio
SESSION_COOKIE_NAME=INTEGRA360_SESSION

# SESSION_COOKIE_SECURE: Transmitir cookie solo sobre HTTPS
# Valores: true | false
# Desarrollo: false (HTTP local)
# Producción: true (HTTPS obligatorio)
SESSION_COOKIE_SECURE=false

# SESSION_COOKIE_HTTP_ONLY: Cookie no accesible por JavaScript
# Valores: true | false
# Recomendado: true (previene XSS)
SESSION_COOKIE_HTTP_ONLY=true

# SESSION_COOKIE_SAME_SITE: Política SameSite para cookies
# Valores: Strict | Lax | None
# Desarrollo: Lax
# Producción: Strict (previene CSRF)
SESSION_COOKIE_SAME_SITE=Lax

# SESSION_TIMEOUT: Tiempo antes de que sesión expire (en minutos)
# Valor: 480 (8 horas)
# Nota: Usuario sin actividad será logout después de esto
SESSION_TIMEOUT=480

# ================================================================================
# 11. CONFIGURACIÓN DE COLAS DE TRABAJO (Job Queue)
# ================================================================================

# QUEUE_DRIVER: Sistema para encolar trabajos asíncronos
# Valores: memory | redis | database | aws_sqs
# Desarrollo: memory (sin persistencia, rápido)
# Producción: redis (persistente, distribuido) o database
QUEUE_DRIVER=memory

# QUEUE_REDIS_URL: Conexión a Redis para colas (si QUEUE_DRIVER=redis)
# Formato: redis://[:password]@host:port/db
QUEUE_REDIS_URL=redis://localhost:6379/1

# QUEUE_RETRY_AFTER: Minutos antes de reintentar job fallido
# Valor: 5 (reintentar después de 5 minutos)
QUEUE_RETRY_AFTER=5

# QUEUE_RETRY_MAX: Máximo de reintentos para un job
# Valor: 3
# Nota: Después de esto, job va a "dead letter queue"
QUEUE_RETRY_MAX=3

# ================================================================================
# 12. CONFIGURACIÓN DE EMAIL
# ================================================================================

# MAIL_FROM_ADDRESS: Dirección de email remitente
# Valor: noreply@integra360.com
MAIL_FROM_ADDRESS=noreply@integra360.com

# MAIL_FROM_NAME: Nombre del remitente en emails
# Valor: Integra360
MAIL_FROM_NAME=Integra360

# MAIL_DRIVER: Servicio de email
# Valores: smtp | sendgrid | mailgun | ses
# Desarrollo: smtp local (mailtrap, etc.)
# Producción: sendgrid, mailgun, o AWS SES
MAIL_DRIVER=smtp

# MAIL_HOST: Host del servidor SMTP
# Desarrollo: smtp.mailtrap.io
# Producción: smtp.gmail.com, smtp.office365.com, etc.
MAIL_HOST=smtp.mailtrap.io

# MAIL_PORT: Puerto del servidor SMTP
# Valores: 587 (TLS), 465 (SSL), 25 (no seguro)
# Recomendado: 587 (TLS)
MAIL_PORT=587

# MAIL_USERNAME: Usuario SMTP
MAIL_USERNAME=your_mailtrap_username

# MAIL_PASSWORD: Contraseña SMTP
# ⚠️ CRÍTICO: No compartir, usar credenciales de producción en deployment
MAIL_PASSWORD=your_mailtrap_password

# MAIL_ENCRYPTION: Tipo de encriptación
# Valores: tls | ssl | null
MAIL_ENCRYPTION=tls

# ================================================================================
# 13. SERVICIOS EXTERNOS Y APIs
# ================================================================================

# PAYMENT_PROVIDER: Proveedor de pagos
# Valores: stripe | mercadopago | paypal
PAYMENT_PROVIDER=stripe

# STRIPE_PUBLIC_KEY: Clave pública de Stripe
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_PUBLIC_KEY=pk_test_your_public_key

# STRIPE_SECRET_KEY: Clave secreta de Stripe
# ⚠️ CRÍTICO: Nunca publicar, solo en backend
STRIPE_SECRET_KEY=sk_test_your_secret_key

# STRIPE_WEBHOOK_SECRET: Secreto para validar webhooks de Stripe
STRIPE_WEBHOOK_SECRET=whsec_test_secret

# ================================================================================
# 14. CONFIGURACIÓN DE ALMACENAMIENTO (S3, etc.)
# ================================================================================

# STORAGE_DRIVER: Sistema de almacenamiento de archivos
# Valores: local | s3 | gcs (Google Cloud Storage)
# Desarrollo: local (en servidor)
# Producción: s3 (escalable, seguro, distribuido)
STORAGE_DRIVER=local

# STORAGE_DISK_PATH: Ruta local para archivos (si STORAGE_DRIVER=local)
# Valor: storage/uploads
STORAGE_DISK_PATH=storage/uploads

# AWS_ACCESS_KEY_ID: Access Key de AWS (si STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=your_aws_access_key

# AWS_SECRET_ACCESS_KEY: Secret Access Key de AWS
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# AWS_DEFAULT_REGION: Región de AWS
# Valor: us-east-1, sa-east-1 (São Paulo, más cercana a Chile)
AWS_DEFAULT_REGION=sa-east-1

# AWS_BUCKET: Nombre del bucket S3
AWS_BUCKET=integra360-uploads

# ================================================================================
# 15. FEATURE FLAGS (Características Experimentales)
# ================================================================================

# FEATURE_RBAC: Activar sistema de control de acceso basado en roles
# Valores: true | false
FEATURE_RBAC=true

# FEATURE_TWO_FACTOR_AUTH: Activar autenticación de dos factores
# Valores: true | false
FEATURE_TWO_FACTOR_AUTH=false

# FEATURE_AUDIT_LOG: Registrar todas las acciones de usuarios
# Valores: true | false
# Nota: Requiere tabla audit_logs en BD
FEATURE_AUDIT_LOG=true

# FEATURE_API_VERSIONING: Soportar múltiples versiones de API
# Valores: true | false
FEATURE_API_VERSIONING=true

# ================================================================================
# 16. CONFIGURACIÓN AVANZADA Y DEBUG
# ================================================================================

# DEBUG: Activar modo debug (más detalles en errores)
# Valores: true | false
# Producción: SIEMPRE false (no exponer pilas de errores)
DEBUG=true

# SENTRY_DSN: URL para enviar errores a Sentry (rastreo de errores)
# Obtener en: https://sentry.io/
# Dejar vacío si no se usa Sentry
SENTRY_DSN=

# SENTRY_ENVIRONMENT: Ambiente en Sentry (para agrupar errores)
# Valor: development | staging | production
SENTRY_ENVIRONMENT=development

# REQUEST_TIMEOUT: Timeout máximo para solicitudes (en segundos)
# Valor: 30
REQUEST_TIMEOUT=30

# ================================================================================
# NOTAS FINALES
# ================================================================================
# 
# 1. DESARROLLO vs PRODUCCIÓN:
#    - Nunca usar valores por defecto en producción
#    - Usar secrets manager (AWS Secrets, HashiCorp Vault, etc.)
#    - Rotar secretos cada 90 días
#
# 2. VALIDACIÓN:
#    - Todas las variables se validan en src/config/env.ts
#    - Si falta una variable requerida, el servidor no inicia
#
# 3. DEPLOYMENT:
#    - Usar variables de entorno del host (Docker, k8s, CI/CD)
#    - No copiar .env.example directamente a producción
#    - Usar herramientas como Ansible, Terraform para provisionar
#
# 4. SEGURIDAD:
#    - Nunca versionar archivos .env
#    - Usar .gitignore para excluir: .env, .env.local, .env.*.local
#    - Auditar acceso a .env.example (contiene estructura sensible)
#
# ===============================================================================
