# ================================================================================
# INTEGRA360 - Configuración de Entorno Frontend
# ================================================================================
# Este archivo define las variables de entorno necesarias para la aplicación
# Vue 3 + Vite. Todas las variables deben estar prefijadas con VITE_ para ser
# accesibles en el código de la aplicación (Vite convención).
#
# Nota: Los valores aquí se "bakeados" en el bundle en build time. No uses
# secretos o credenciales en variables frontend.
# ================================================================================

# ================================================================================
# 1. CONFIGURACIÓN DE API
# ================================================================================

# VITE_API_BASE_URL: URL base del servidor API backend
# Desarrollo: http://localhost:3000/api/v1 (servidor local)
# Staging: https://api-staging.integra360.com/api/v1
# Producción: https://api.integra360.com/api/v1
# Nota: Asegurarse que coincida con CORS_ORIGIN del backend
VITE_API_BASE_URL=http://localhost:3000/api/v1

# VITE_API_TIMEOUT: Timeout para solicitudes HTTP (en milisegundos)
# Valor: 30000 (30 segundos)
# Nota: Aumentar si backend está lento en desarrollo
VITE_API_TIMEOUT=30000

# ================================================================================
# 2. CONFIGURACIÓN DE APLICACIÓN
# ================================================================================

# VITE_APP_NAME: Nombre de la aplicación
# Uso: En título de página, headers, breadcrumbs
VITE_APP_NAME=Integra360

# VITE_APP_VERSION: Versión de la aplicación
# Formato: major.minor.patch (semver)
# Nota: Sincronizar con package.json version
VITE_APP_VERSION=1.0.0

# VITE_APP_TITLE: Título en pestaña del navegador
# Formato: Breve, bajo 60 caracteres
VITE_APP_TITLE=Integra360 - Sistema de Gestión Integral

# VITE_APP_DESCRIPTION: Descripción de la aplicación
# Uso: Meta description para SEO, Open Graph
VITE_APP_DESCRIPTION=Sistema modular de gestión empresarial con autenticación, dashboard y reportes

# ================================================================================
# 3. CONFIGURACIÓN REGIONAL Y LOCALIZACIÓN
# ================================================================================

# VITE_LOCALE: Idioma/región por defecto
# Valor: es-CL (Español - Chile)
# Nota: Usado para formateo de fechas, números, moneda
VITE_LOCALE=es-CL

# VITE_TIMEZONE: Zona horaria de la aplicación
# Valor: America/Santiago (Chile)
# Nota: Para visualización de timestamps
VITE_TIMEZONE=America/Santiago

# VITE_CURRENCY: Código de moneda ISO 4217
# Valor: CLP (Peso Chileno)
VITE_CURRENCY=CLP

# VITE_CURRENCY_SYMBOL: Símbolo de moneda para UI
# Valor: $ (Peso)
VITE_CURRENCY_SYMBOL=$

# VITE_DATE_FORMAT: Formato de fechas en UI
# Valor: DD/MM/YYYY (estándar Latinoamericano)
# Alternativas: YYYY-MM-DD (ISO), MM/DD/YYYY (US)
VITE_DATE_FORMAT=DD/MM/YYYY

# VITE_TIME_FORMAT: Formato de hora en UI
# Valor: HH:mm:ss (24 horas)
VITE_TIME_FORMAT=HH:mm:ss

# ================================================================================
# 4. CONFIGURACIÓN DE FEATURES Y FLAGS
# ================================================================================

# VITE_ENABLE_CHARTS: Activar gráficos de Chart.js
# Valores: true | false
VITE_ENABLE_CHARTS=true

# VITE_ENABLE_EXPORT_PDF: Habilitar descarga de reportes PDF
# Valores: true | false
# Nota: Requiere pdfkit o librería similar en backend
VITE_ENABLE_EXPORT_PDF=true

# VITE_ENABLE_EXPORT_EXCEL: Habilitar descarga de datos a Excel
# Valores: true | false
# Nota: Requiere xlsx librería en frontend
VITE_ENABLE_EXPORT_EXCEL=true

# VITE_ENABLE_DARK_MODE: Activar soporte para tema oscuro
# Valores: true | false
# Nota: Requiere TailwindCSS dark: 'class' en config
VITE_ENABLE_DARK_MODE=false

# VITE_ENABLE_NOTIFICATIONS: Activar notificaciones (SweetAlert2, Toast)
# Valores: true | false
VITE_ENABLE_NOTIFICATIONS=true

# ================================================================================
# 5. CONFIGURACIÓN DE AUTENTICACIÓN
# ================================================================================

# VITE_AUTH_TOKEN_STORAGE: Dónde almacenar tokens JWT
# Valores: localStorage | sessionStorage
# localStorage: Persisten entre sessiones (menos seguro)
# sessionStorage: Solo durante la sesión (más seguro)
# Nota: Para máxima seguridad, usar httpOnly cookies en backend
VITE_AUTH_TOKEN_STORAGE=localStorage

# VITE_AUTH_TOKEN_KEY: Nombre de la clave en storage para token acceso
# Valor: access_token (por convenio)
VITE_AUTH_TOKEN_KEY=access_token

# VITE_AUTH_REFRESH_TOKEN_KEY: Nombre de clave para token refresco
# Valor: refresh_token
VITE_AUTH_REFRESH_TOKEN_KEY=refresh_token

# VITE_AUTH_REDIRECT_LOGIN: URL a la que redirigir si no autenticado
# Valor: /auth/login
VITE_AUTH_REDIRECT_LOGIN=/auth/login

# VITE_AUTH_REDIRECT_AFTER_LOGIN: URL a la que ir después de login exitoso
# Valor: /dashboard
VITE_AUTH_REDIRECT_AFTER_LOGIN=/dashboard

# ================================================================================
# 6. CONFIGURACIÓN DE ANALYTICS Y TRACKING
# ================================================================================

# VITE_GOOGLE_ANALYTICS_ID: ID de Google Analytics
# Obtener en: https://analytics.google.com/
# Dejar vacío para deshabilitar analytics
# Valor: G-XXXXXXXXXX
VITE_GOOGLE_ANALYTICS_ID=

# VITE_SENTRY_DSN: URL de Sentry para rastreo de errores frontend
# Obtener en: https://sentry.io/
# Dejar vacío para deshabilitar Sentry
VITE_SENTRY_DSN=

# VITE_SENTRY_ENVIRONMENT: Ambiente en Sentry (development, staging, production)
# Valor: development
VITE_SENTRY_ENVIRONMENT=development

# ================================================================================
# 7. CONFIGURACIÓN VITE (Build)
# ================================================================================

# VITE_SOURCEMAP: Generar source maps para debugging
# Valores: true | false
# Desarrollo: true (fácil debugging)
# Producción: false (archivos más pequeños, no exponer código)
# Nota: Se puede controlar en vite.config.js también
VITE_SOURCEMAP=true

# ================================================================================
# 8. CONFIGURACIÓN DE BASE URL DE ASSETS
# ================================================================================

# VITE_PUBLIC_PATH: Ruta base de activos estáticos
# Valor: / (raíz del dominio)
# Alternativa: /app/ (si está en subdirectorio)
# Nota: Configurado también en vite.config.js
VITE_PUBLIC_PATH=/

# ================================================================================
# NOTAS FINALES
# ================================================================================
#
# 1. VARIABLES VITE_:
#    - TODAS las variables deben empezar con VITE_
#    - Solo variables VITE_ se expondrán en el código cliente
#    - Las demás se ignoran (esto es una característica de Vite)
#
# 2. BUILD TIME vs RUNTIME:
#    - Variables VITE_ se bakeadas en el bundle (build time)
#    - No se pueden cambiar sin rebuild
#    - Para configuración runtime, usar variables HTML en index.html
#
# 3. SEGURIDAD:
#    - NUNCA poner secretos (API keys privadas, tokens) aquí
#    - Los valores frontend son públicos (visible en network tab)
#    - Solo usar para: URLs públicas, toggles de feature, IDs públicos
#
# 4. DESARROLLO LOCAL:
#    - Crear archivo .env.local para sobrescribir valores
#    - Gitignore: .env.local, .env.*.local
#
# 5. SINCRONIZACIÓN BACKEND-FRONTEND:
#    - VITE_API_BASE_URL debe coincidir con CORS_ORIGIN del backend
#    - VITE_LOCALE debe coincidir con LOCALE del backend
#    - VITE_TIMEZONE debe coincidir con TZ del backend
#
# ===============================================================================
