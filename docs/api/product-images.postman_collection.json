{
  "info": {
    "_postman_id": "2fef3f2e-4e7a-4e5b-a3d6-3c35d7c7f4e1",
    "name": "Integra360 - Product Images API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection to test product image CRUD endpoints end-to-end, including multipart upload."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {", 
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.accessToken);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Product Images",
      "item": [
        {
          "name": "List Product Images",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-company-id",
                "value": "{{companyId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}",
                "images"
              ]
            }
          }
        },
        {
          "name": "Upload Product Image (multipart)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-company-id",
                "value": "{{companyId}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "{{imagePath}}"
                },
                {
                  "key": "purpose",
                  "value": "GALLERY",
                  "type": "text"
                },
                {
                  "key": "altText",
                  "value": "Vista lateral del producto",
                  "type": "text"
                },
                {
                  "key": "sortOrder",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "isPrimary",
                  "value": "false",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}",
                "images"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {", 
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('imageId', String(json.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Patch Product Image Metadata",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-company-id",
                "value": "{{companyId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"DETAIL\",\n  \"altText\": \"Detalle frontal actualizado\",\n  \"sortOrder\": 2,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}",
                "images",
                "{{imageId}}"
              ]
            }
          }
        },
        {
          "name": "Mark Product Image as Primary",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-company-id",
                "value": "{{companyId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}/primary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}",
                "images",
                "{{imageId}}",
                "primary"
              ]
            }
          }
        },
        {
          "name": "Delete Product Image",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "x-company-id",
                "value": "{{companyId}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}",
                "images",
                "{{imageId}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "email",
      "value": "john@example.com"
    },
    {
      "key": "password",
      "value": "Secret123!"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "companyId",
      "value": "1"
    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "imageId",
      "value": ""
    },
    {
      "key": "imagePath",
      "value": "C:/temp/product-image.jpg"
    }
  ]
}
