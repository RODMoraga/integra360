{
  "info": {
    "_postman_id": "f8a4c1f8-cc53-4f1a-bf8b-b1f4b10ea0a2",
    "name": "Integra360 - Product Images Newman",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection optimized for Newman CI/CD execution of product image endpoints."
  },
  "item": [
    {
      "name": "0. Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"CI API User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 201 or 409', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([201, 409]);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "1. Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('accessToken exists', function () { pm.expect(body.accessToken).to.be.a('string').and.not.empty; });",
              "pm.collectionVariables.set('accessToken', body.accessToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Upload Product Image",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "x-company-id",
            "value": "{{companyId}}"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "src": "{{imagePath}}"
            },
            {
              "key": "purpose",
              "value": "GALLERY",
              "type": "text"
            },
            {
              "key": "altText",
              "value": "Imagen de prueba CI",
              "type": "text"
            },
            {
              "key": "sortOrder",
              "value": "1",
              "type": "text"
            },
            {
              "key": "isPrimary",
              "value": "false",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "{{productId}}",
            "images"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 201', function () { pm.response.to.have.status(201); });",
              "const body = pm.response.json();",
              "pm.test('created image id exists', function () { pm.expect(body.id).to.exist; });",
              "pm.collectionVariables.set('imageId', String(body.id));"
            ]
          }
        }
      ]
    },
    {
      "name": "3. List Product Images",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "x-company-id",
            "value": "{{companyId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "{{productId}}",
            "images"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 200', function () { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('response is array', function () { pm.expect(Array.isArray(body)).to.eql(true); });"
            ]
          }
        }
      ]
    },
    {
      "name": "4. Patch Product Image",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "x-company-id",
            "value": "{{companyId}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"purpose\": \"DETAIL\",\n  \"altText\": \"Actualizado por Newman\",\n  \"sortOrder\": 2,\n  \"isActive\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "{{productId}}",
            "images",
            "{{imageId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 204', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Mark Image Primary",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "x-company-id",
            "value": "{{companyId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}/primary",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "{{productId}}",
            "images",
            "{{imageId}}",
            "primary"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 204', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Delete Product Image",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "x-company-id",
            "value": "{{companyId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/products/{{productId}}/images/{{imageId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "products",
            "{{productId}}",
            "images",
            "{{imageId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('HTTP 204', function () { pm.response.to.have.status(204); });"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "imageId",
      "value": ""
    }
  ]
}
